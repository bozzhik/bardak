{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,

    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./src/components/*"],
      "~~/*": ["./src/components/app/*"],
      "$/*": ["./src/assets/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "next-env.d.ts", "next.config.js", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
